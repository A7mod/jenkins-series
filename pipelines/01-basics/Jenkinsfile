pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                echo 'Checking out code...'
            }
        }
        stage('Build') {
            steps {
                echo 'Building the application...'
                sh 'echo "Simulating a build step"'
            }
        }
        stage('Test') {
            steps {
                echo 'Running tests...'
                sh 'echo "Simulating tests passing"'
            }
        }
    }

    post {
        always {
            echo 'Pipeline finished.'
        }
        success {
            echo 'Pipeline succeeded!'
        }
        failure {
            echo 'Pipeline failed!'
        }
    }
}
